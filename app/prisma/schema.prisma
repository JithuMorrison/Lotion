generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String  @id @default(cuid())
  name      String
  email     String  @unique
  avatarUrl String?
}

model Page {
  id            String    @id @default(cuid())
  title         String
  icon          String?
  coverUrl      String?
  blocksContent Json
  parentId      String?
  parent        Page?     @relation("PageChildren", fields: [parentId], references: [id])
  children      Page[]    @relation("PageChildren")
  entry         Entry?
  database      Database?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Database {
  id         String     @id @default(cuid())
  pageId     String     @unique
  page       Page       @relation(fields: [pageId], references: [id])
  properties Property[]
  entries    Entry[]
  views      View[]
}

model Property {
  id         String   @id @default(cuid())
  name       String
  type       String
  options    Json?
  databaseId String
  database   Database @relation(fields: [databaseId], references: [id])
}

model Entry {
  id         String   @id @default(cuid())
  pageId     String   @unique
  page       Page     @relation(fields: [pageId], references: [id])
  databaseId String
  database   Database @relation(fields: [databaseId], references: [id])
  isTemplate Boolean  @default(false)
  values     Json
}

model View {
  id         String   @id @default(cuid())
  name       String
  type       String
  config     Json
  databaseId String
  database   Database @relation(fields: [databaseId], references: [id])
}
